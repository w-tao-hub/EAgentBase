# 本文件用于说明本地开发环境所需的配置项。
# 使用方式：复制为 `.env` 后按本地环境修改具体值。

# ===== 应用入口配置 =====

# APP_HOST
# 说明：HTTP 服务监听的主机地址。
# 作用：决定 FastAPI / Uvicorn 绑定到哪个网络接口；本地开发通常使用 `127.0.0.1`。
APP_HOST=

# APP_PORT
# 说明：HTTP 服务监听端口。
# 作用：决定本地访问服务时使用的端口号，默认 `8000` 便于后续接口调试。
APP_PORT=

# APP_ENV
# 说明：应用运行环境标识，可选值：dev（开发）、prod（生产）。
# 作用：控制 API 文档显示/隐藏，以及 Uvicorn 启动模式（热加载、工作进程数）。
#       dev 环境启用 API 文档和热加载，prod 环境关闭文档并使用多进程。
APP_ENV=


# ===== 会话 配置 =====

# CONTEXT_TOKEN_THRESHOLD
# 说明：触发上下文压缩的输入 token 阀值。
# 作用：当待发送给模型的输入上下文超过该阀值时，会先清理旧的 query_tool_result / skill 注入痕迹，
#       若仍高于阀值的三分之二，则进一步生成压缩摘要；`0` 表示关闭该能力。
CONTEXT_TOKEN_THRESHOLD=

# ===== Redis 配置 =====

# REDIS_MODE
# 说明：Redis 连接模式，可选值：single（单点）、sentinel（Sentinel）。
# 作用：控制容器应直接连接单点 Redis，还是先通过 Sentinel 发现当前 master。
REDIS_MODE=single

# REDIS_URL
# 说明：单点模式下使用的 Redis 连接地址，格式为 redis://[:密码@]主机:端口/库号。
# 作用：当 REDIS_MODE=single 时，会话元数据、消息历史、运行状态和会话锁都会通过这条连接串访问 Redis。
#       如需密码认证，格式为 redis://:your_password@host:6379/0
REDIS_URL=

# REDIS_SENTINEL_NODES
# 说明：Sentinel 模式下的 Sentinel 节点列表，使用逗号分隔多个 host:port。
# 作用：当 REDIS_MODE=sentinel 时，应用会先连接这些 Sentinel 节点，再发现当前 master。
# 示例：REDIS_SENTINEL_NODES=127.0.0.1:26379,127.0.0.2:26379
# REDIS_SENTINEL_NODES=

# REDIS_SENTINEL_MASTER_NAME
# 说明：Sentinel 模式下的 master service name。
# 作用：当 REDIS_MODE=sentinel 时，应用会使用该名称向 Sentinel 查询当前主节点。
# 示例：REDIS_SENTINEL_MASTER_NAME=mymaster
# REDIS_SENTINEL_MASTER_NAME=

# REDIS_DB
# 说明：Sentinel 模式下主 Redis 使用的逻辑库编号。
# 作用：当 REDIS_MODE=sentinel 时，master 客户端会连接到该 db；默认 `0`。
REDIS_DB=0

# REDIS_USERNAME
# 说明：Redis 用户名。
# 作用：当前版本默认让 Sentinel 与 master 共用同一套认证信息；单点模式通常直接写在 REDIS_URL 中。
# 示例：REDIS_USERNAME=default
# REDIS_USERNAME=

# REDIS_PASSWORD
# 说明：Redis 密码。
# 作用：当前版本默认让 Sentinel 与 master 共用同一套认证信息；单点模式通常直接写在 REDIS_URL 中。
# 示例：REDIS_PASSWORD=your_password
# REDIS_PASSWORD=

# REDIS_KEY_PREFIX
# 说明：Redis 键前缀。
# 作用：用于隔离当前项目在 Redis 中写入的键，避免与其他项目或环境互相污染。
#       例如会话键为 `agent:session:{id}`，消息键为 `agent:messages:{id}`。
REDIS_KEY_PREFIX=

# SESSION_LOCK_TTL_SECONDS
# 说明：会话活跃运行锁的过期时间，单位为秒。
# 作用：限制同一会话同时只有一个运行在执行，并在异常情况下依靠 TTL 自动释放锁。
# 锁续期，需避免过短导致误释放，也避免过长导致冲突恢复过慢。ttl_seconds / 2)，默认 TTL=30 → 每 15 秒续期一次
SESSION_LOCK_TTL_SECONDS=

# ===== LiteLLM 配置 =====

# LITELLM_TIMEOUT_SECONDS
# 说明：LiteLLM 请求超时时间，单位为秒。
# 作用：限制模型调用最长等待时间，避免上游模型长时间无响应拖住当前运行。
LITELLM_TIMEOUT_SECONDS=

# ===== CORS 跨域配置 =====

# CORS_ALLOW_ORIGINS
# 说明：允许的源地址列表，JSON 数组格式。
# 作用：控制哪些域名可以跨域访问 API；生产环境应配置具体域名，如 ["https://example.com"]。
CORS_ALLOW_ORIGINS=

# CORS_ALLOW_CREDENTIALS
# 说明：是否允许跨域请求携带凭证。
# 作用：控制浏览器是否允许发送 Cookie、Authorization 头等凭证信息。
CORS_ALLOW_CREDENTIALS=

# CORS_ALLOW_METHODS
# 说明：允许的 HTTP 方法列表，JSON 数组格式。
# 作用：控制跨域请求允许的 HTTP 方法，通常使用 ["GET", "POST", "PUT", "DELETE", "OPTIONS"]。
CORS_ALLOW_METHODS=

# CORS_ALLOW_HEADERS
# 说明：允许的 HTTP 请求头列表，JSON 数组格式。
# 作用：控制跨域请求可以携带哪些自定义请求头，如 ["Authorization", "Content-Type"]。
CORS_ALLOW_HEADERS=

# ===== Uvicorn 服务器配置 =====

# UVICORN_WORKERS
# 说明：Uvicorn 工作进程数。
# 作用：生产环境并发处理能力，默认等于 CPU 核心数；开发环境强制为 1。
UVICORN_WORKERS=

# UVICORN_TIMEOUT_KEEP_ALIVE
# 说明：HTTP keep-alive 连接超时时间，单位为秒。
# 作用：控制长连接保持时间，默认 5 秒。
UVICORN_TIMEOUT_KEEP_ALIVE=

# UVICORN_FORWARDED_ALLOW_IPS
# 说明：信任的代理 IP 地址。
# 作用：用于正确处理 X-Forwarded-* 头；使用 * 表示信任所有，生产环境应配置具体 IP。
UVICORN_FORWARDED_ALLOW_IPS=

# UVICORN_ACCESS_LOG
# 说明：是否启用访问日志。
# 作用：记录每个 HTTP 请求的访问日志，生产环境建议开启以便监控。
UVICORN_ACCESS_LOG=

# ===== 主智能体配置 =====

# MASTER_AGENT_ID
# 说明：默认主智能体的唯一标识。
# 作用：创建会话与运行时装配主智能体时使用该标识，默认值为 `master-agent`。
MASTER_AGENT_ID=

# MASTER_AGENT_NAME
# 说明：默认主智能体的展示名称。
# 作用：用于 API 视图与运行时上下文中的可读名称展示，默认值为 `Master Agent`。
MASTER_AGENT_NAME=

# MASTER_AGENT_MODEL
# 说明：默认主智能体使用的模型标识。
# 作用：传递给 LiteLLM 作为上游模型选择参数，默认值为 `deepseek/deepseek-chat`。
MASTER_AGENT_MODEL=

# MASTER_AGENT_TEMPERATURE
# 说明：默认主智能体的温度参数。
# 作用：控制模型输出随机性，默认值为 `0.2`，数值越高通常越发散。
MASTER_AGENT_TEMPERATURE=

# MASTER_AGENT_REASONING_EFFORT
# 说明：默认主智能体的思考强度。
# 作用：控制 DeepSeek V4 thinking 模型的思考强度，当前仅支持 `high` 与 `max`。
MASTER_AGENT_REASONING_EFFORT=

# RUN_TTL_SECONDS
# 说明：Run 记录在 Redis 中的过期时间，单位为秒。
# 作用：控制历史 Run 数据在 Redis 中的保留时长，过期后自动清理，默认 7 天（604800 秒）。
RUN_TTL_SECONDS=

# ===== 日志配置 =====

# LOG_LEVEL
# 说明：应用日志级别，可选值：debug、info、error。
# 作用：控制日志输出的详细程度，debug 最详细，error 仅错误信息。
LOG_LEVEL=

# LOG_DIR
# 说明：日志文件存放目录，相对于项目根目录。
# 作用：指定日志文件的存储位置，默认为项目根目录下的 logs/ 文件夹。
LOG_DIR=

# LOG_FILE_NAME
# 说明：日志文件名前缀。
# 作用：实际文件名为 {LOG_FILE_NAME}_YYYYMMDD.log，默认为 app。
LOG_FILE_NAME=

# LOG_CONSOLE_OUTPUT
# 说明：兼容旧配置保留。
# 作用：当前代码已固定为开发环境输出到 stdout + 文件，生产环境只写文件；此项暂不再实际控制行为。
LOG_CONSOLE_OUTPUT=

# LOG_MAX_BYTES
# 说明：单个日志文件最大大小，单位为字节。
# 作用：超过该大小后即使未到午夜也会触发轮转，0 表示不限制大小。默认 10MB (10485760)。
LOG_MAX_BYTES=

# LOG_QUEUE_MAXSIZE
# 说明：日志异步队列的最大容量。
# 作用：限制后台日志队列占用的内存上限；队列满时 DEBUG / INFO 直接丢弃，WARNING / ERROR 尝试优先保底。
LOG_QUEUE_MAXSIZE=

# ===== 模型服务商凭据 =====

# DEEPSEEK_API_KEY
# 说明：DeepSeek 平台的 API 密钥。
# 作用：LiteLLM 调用 DeepSeek 模型时通过此密钥进行身份认证，缺少则请求会被拒绝。
#       获取方式：登录 https://platform.deepseek.com 在 API Keys 页面创建。
DEEPSEEK_API_KEY=

# ===== AgentLoop 配置 =====

# AGENT_MAX_TURNS
# 说明：AgentLoop 的最大轮数限制。
# 作用：控制单个会话中 Agent 与模型交互的最大轮数，防止工具调用循环或异常导致无限循环。
#       超过此轮数后循环将强制终止并返回 MAX_TURNS_EXCEEDED 错误。
AGENT_MAX_TURNS=

# WORKSPACE_ROOT
# 说明：RunPythonScriptTool 的工作区根目录路径。
# 作用：限制 python 脚本执行工具的搜索范围，确保工具只能执行指定目录内的 .py 脚本文件。
# 路径可以是绝对路径或相对路径，相对路径基于应用启动目录解析。绝对路径以 / 开头。
WORKSPACE_ROOT=

# MCP_SERVERS_CONFIG_PATH
# 说明：MCP 服务配置文件路径。
# 作用：指向项目内用于声明多个 MCP server 的 JSON 配置文件，默认使用项目根目录下的 `mcp_servers.json`。
#       文件内容应为 JSON 数组，每项声明 server_id、transport 以及对应的 stdio 或 streamable-http 参数。
MCP_SERVERS_CONFIG_PATH=
